NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

CRON_SECRET=your-random-32-char-secret-here
NEXT_PUBLIC_CRON_SECRET=your-random-32-char-secret-here

# Public data API keys
# No key needed: Open-Meteo, REST Countries, Teleport, World Bank
GOOGLE_PLACES_API_KEY=      # Google Cloud Console — Places API (schools, places, photos)
AQICN_TOKEN=                # aqicn.org/data-platform/token — real-time air quality (free, 1000/day)
GROQ_API_KEY=               # console.groq.com — LLM for onboarding chat (free, 14k/day)
IQAIR_API_KEY=              # iqair.com/air-pollution-data-api — air quality (free, 10k/month)
OPENWEATHERMAP_API_KEY=     # home.openweathermap.org/users/sign_up — weather (free, 1000/day)
EXCHANGE_RATE_API_KEY=      # app.exchangerate-api.com/sign-up — currency (free, 1500/month)
NUMBEO_API_KEY=             # numbeo.com/api — cost of living (PAID $30/mo, defer)
TRAVEL_BUDDY_API_KEY=       # travel-buddy.ai/api — visa requirements (free tier)
